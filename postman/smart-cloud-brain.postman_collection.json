                  "pm.test('admin login succeeds', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('admin token returned', () => pm.expect(body.data.token).to.be.a('string').and.not.empty);",
                  "pm.environment.set('adminToken', body.data.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"account\": \"admin\",\n  \"password\": \"123456\"\n}"
            },
            "url": "{{baseUrl}}/api/admin/login"
          }
        },
        {
          "name": "Generate Schedule Suggestions",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('schedule suggestions generated', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('schedule generation business result succeeds', () => pm.expect(body.code).to.eql(0));",
                  "pm.test('at least one suggestion exists', () => pm.expect(body.data.length).to.be.greaterThan(0));",
                  "pm.test('real Dify suggestions are returned', () => pm.expect(body.data.every(item => item.source === 'dify' && item.degraded === false)).to.eql(true));",
                  "const selected = body.data[0];",
                  "pm.environment.set('scheduleSuggestionId', selected.id);",
                  "pm.environment.set('scheduleSuggestionIds', JSON.stringify(body.data.slice(0, 2).map(item => item.id)));",
                  "pm.environment.set('scheduledDoctorId', selected.doctorId);",
                  "pm.environment.set('scheduledDepartmentId', selected.departmentId);",
                  "pm.environment.set('scheduledWorkDate', selected.workDate);",
                  "pm.environment.set('scheduledTimeRange', selected.timeRange);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"startDate\": \"{{scheduleStartDate}}\",\n  \"days\": 2\n}"
            },
            "url": "{{baseUrl}}/api/admin/schedule/generate"
          }
        },
