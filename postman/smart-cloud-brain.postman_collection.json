{
  "info": {
    "name": "Smart Cloud Brain",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/actuator/health",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "actuator",
            "health"
          ]
        }
      }
    },
    {
      "name": "Patient Register",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"测试患者\",\n  \"phone\": \"13800000001\",\n  \"password\": \"123456\",\n  \"gender\": \"FEMALE\",\n  \"age\": 30\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/patients/register",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "patients",
            "register"
          ]
        }
      }
    },
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"account\": \"13800000001\",\n  \"password\": \"123456\",\n  \"role\": \"PATIENT\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "login"
          ]
        }
      }
    },
    {
      "name": "Triage",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"chiefComplaint\": \"胸闷胸痛 2 小时\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/triage",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "triage"
          ]
        }
      }
    }
  ]
}
