                "type": "text/javascript",
                "exec": [
                  "pm.test('suggestion detail can be read', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('suggestion detail business result succeeds', () => pm.expect(body.code).to.eql(0));",
                  "pm.test('detail matches selected suggestion', () => pm.expect(String(body.data.id)).to.eql(String(pm.environment.get('scheduleSuggestionId'))));"
                ]
              }
            }
          ],
          "request": {
