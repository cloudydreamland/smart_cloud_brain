  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Gateway Health",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const start = new Date();",
                  "const offsetDays = 30 + (Math.floor(Date.now() / 1000) % 3650);",
                  "start.setDate(start.getDate() + offsetDays);",
                  "const yyyy = start.getFullYear();",
                  "const mm = String(start.getMonth() + 1).padStart(2, '0');",
                  "const dd = String(start.getDate()).padStart(2, '0');",
                  "pm.environment.set('scheduleStartDate', `${yyyy}-${mm}-${dd}`);",
                  "['scheduleSuggestionId', 'scheduleSuggestionIds', 'scheduledDoctorId', 'scheduledDepartmentId', 'scheduledWorkDate', 'scheduledTimeRange', 'slotId', 'slotDoctorId', 'slotDepartmentId', 'slotStartTime', 'registrationId', 'cancelRegistrationId', 'medicalRecordId', 'prescriptionId'].forEach(key => pm.environment.unset(key));"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('gateway is healthy', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/actuator/health"
          }
        }
      ]
    },
    {
      "name": "Admin schedule workflow",
