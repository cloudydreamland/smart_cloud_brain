{
  "info": {
    "name": "Smart Cloud Brain - Light Diagnosis Chain",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/actuator/health"
      }
    },
    {
      "name": "Patient Register",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"测试患者\",\n  \"phone\": \"13800000001\",\n  \"password\": \"123456\",\n  \"gender\": \"FEMALE\",\n  \"age\": 21\n}"
        },
        "url": "{{baseUrl}}/api/patient/register"
      }
    },
    {
      "name": "Patient Login",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"account\": \"13800000001\",\n  \"password\": \"123456\"\n}"
        },
        "url": "{{baseUrl}}/api/patient/login"
      }
    },
    {
      "name": "AI Triage",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{patientToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"chiefComplaint\": \"咽痛、低热、鼻塞两天，想预约轻症门诊。\"\n}"
        },
        "url": "{{baseUrl}}/api/triage/consult"
      }
    },
    {
      "name": "Create Registration",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{patientToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"doctorId\": 2,\n  \"departmentId\": 2,\n  \"appointmentTime\": \"2026-06-15T09:00:00\",\n  \"triageRecordId\": 1\n}"
        },
        "url": "{{baseUrl}}/api/registration/create"
      }
    },
    {
      "name": "Doctor Login",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"account\": \"13900000002\",\n  \"password\": \"123456\"\n}"
        },
        "url": "{{baseUrl}}/api/doctor/login"
      }
    },
    {
      "name": "Generate Medical Record",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{doctorToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"registrationId\": 1,\n  \"departmentCode\": \"GENERAL\",\n  \"dialogueText\": \"患者咽痛、鼻塞、低热两天，无胸痛和呼吸困难。\"\n}"
        },
        "url": "{{baseUrl}}/api/medical-record/generate"
      }
    },
    {
      "name": "Save Medical Record",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{doctorToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"registrationId\": 1,\n  \"chiefComplaint\": \"咽痛、鼻塞、低热两天\",\n  \"presentIllness\": \"症状较轻，无危险信号。\",\n  \"physicalExam\": \"咽部轻度充血。\",\n  \"diagnosis\": \"普通感冒待观察\",\n  \"treatmentAdvice\": \"休息、补液，必要时复诊。\",\n  \"aiGenerated\": true\n}"
        },
        "url": "{{baseUrl}}/api/medical-record/save"
      }
    },
    {
      "name": "AI Prescription Check",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{doctorToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"patientId\": 1,\n  \"doctorId\": 2,\n  \"drugs\": [\n    {\"drugName\":\"对乙酰氨基酚\",\"dosage\":\"0.5g\",\"frequency\":\"必要时\",\"usageMethod\":\"口服\"}\n  ]\n}"
        },
        "url": "{{baseUrl}}/api/prescription/check"
      }
    },
    {
      "name": "Create Prescription",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{doctorToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"patientId\": 1,\n  \"medicalRecordId\": 1,\n  \"riskLevel\": \"LOW\",\n  \"drugs\": [\n    {\"drugName\":\"对乙酰氨基酚\",\"dosage\":\"0.5g\",\"frequency\":\"必要时\",\"usageMethod\":\"口服\"}\n  ]\n}"
        },
        "url": "{{baseUrl}}/api/prescription/create"
      }
    },
    {
      "name": "Patient Records",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{patientToken}}" }],
        "url": "{{baseUrl}}/api/medical-record/list"
      }
    }
  ]
}
