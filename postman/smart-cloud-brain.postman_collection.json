  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Gateway Health",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('gateway is healthy', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/actuator/health"
          }
        }
      ]
    },
    {
      "name": "Admin schedule workflow",
      "item": [
        {
          "name": "Admin Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('admin login succeeds', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('admin token returned', () => pm.expect(body.data.token).to.be.a('string').and.not.empty);",
                  "pm.environment.set('adminToken', body.data.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"account\": \"admin\",\n  \"password\": \"123456\"\n}"
            },
            "url": "{{baseUrl}}/api/admin/login"
          }
        },
        {
          "name": "Generate Schedule Suggestions",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('schedule suggestions generated', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('at least one suggestion exists', () => pm.expect(body.data.length).to.be.greaterThan(0));",
                  "pm.environment.set('scheduleSuggestionId', body.data[0].id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"startDate\": \"{{scheduleStartDate}}\",\n  \"days\": 2\n}"
            },
            "url": "{{baseUrl}}/api/admin/schedule/generate"
          }
        },
        {
          "name": "Schedule Suggestion Detail",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('suggestion detail can be read', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('detail matches selected suggestion', () => pm.expect(String(body.data.id)).to.eql(String(pm.environment.get('scheduleSuggestionId'))));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/api/admin/schedule/suggestion/detail?id={{scheduleSuggestionId}}"
          }
        },
        {
          "name": "Publish Schedule",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('schedule publish succeeds', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('published schedules are returned', () => pm.expect(body.data).to.be.an('array'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"suggestionIds\": [{{scheduleSuggestionId}}]\n}"
            },
            "url": "{{baseUrl}}/api/admin/schedule/publish"
          }
        },
        {
          "name": "System Dict List",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('admin can read dictionaries', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('dictionary response is an array', () => pm.expect(body.data).to.be.an('array'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/api/admin/dict/list"
          }
        }
      ]
    },
