DB_NAME=smart_cloud_brain_demo
DB_USERNAME=scb_demo
DB_PASSWORD=replace-with-demo-db-password
DB_ROOT_PASSWORD=replace-with-demo-root-password
KINGBASE_SYSTEM_PASSWORD=replace-with-demo-kingbase-system-password
DB_PORT=54321
DB_SERVICE_HOST=kingbase
DB_SERVICE_PORT=54321

KINGBASE_IMAGE=kingbase_v009r001c010b0004_single_x86:v1
KINGBASE_DB_MODE=pg
DB_INTERNAL_PORT=54321
DB_DATA_DIR=/home/kingbase/userdata/data

RABBITMQ_USERNAME=scb_demo
RABBITMQ_PASSWORD=replace-with-demo-rabbitmq-password
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

JWT_SECRET=replace-with-demo-random-secret-at-least-32-bytes
INTERNAL_SERVICE_TOKEN=replace-with-demo-random-internal-token-at-least-32-bytes
NOTIFICATION_WS_ALLOWED_ORIGINS=http://localhost:5174,http://127.0.0.1:5174
JWT_EXPIRE_HOURS=8
GATEWAY_PORT=18080

JAVA_TOOL_OPTIONS=-XX:MaxRAMPercentage=70 -XX:+ExitOnOutOfMemoryError
JAVA_SERVICE_CPUS=0.75
JAVA_SERVICE_MEM_LIMIT=768m
INFRA_CPUS=0.75
INFRA_MEM_LIMIT=768m
WEB_CPUS=0.35
WEB_MEM_LIMIT=256m

AI_PROVIDER=mock
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=
AI_TIMEOUT_MS=8000
AI_MAX_RETRIES=1
AI_MAX_CONCURRENCY=8
AI_SERVICE_TIMEOUT_MS=5000
