DB_NAME=smart_cloud_brain
DB_USERNAME=scb
DB_PASSWORD=scb_password
DB_ROOT_PASSWORD=root_password
DB_PORT=54321
DB_SERVICE_HOST=kingbase
DB_SERVICE_PORT=5432

# Default local demo mode uses the embedded-db profile and a public PostgreSQL image.
# This is PostgreSQL/Kingbase-compatible for development; it is NOT a real KingbaseES image.
#
# Start default demo mode with:
# docker-compose --env-file deploy\env\.env -f deploy\docker-compose.yml --profile embedded-db up -d --build
#
# For a real KingbaseES Docker image, set:
# KINGBASE_IMAGE=<your-kingbase-image>
# DB_INTERNAL_PORT=54321
# DB_DATA_DIR=/var/lib/kingbase
# DB_SERVICE_HOST=kingbase
# DB_SERVICE_PORT=54321
#
# For an external KingbaseES instance, run without --profile embedded-db and set:
# DB_SERVICE_HOST=host.docker.internal
# DB_SERVICE_PORT=15432
# DB_USERNAME=system
# DB_PASSWORD=123456
KINGBASE_IMAGE=postgres:16-alpine
DB_INTERNAL_PORT=5432
DB_DATA_DIR=/var/lib/postgresql/data

RABBITMQ_USERNAME=scb
RABBITMQ_PASSWORD=scb_password
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRE_HOURS=24
GATEWAY_PORT=18080

AI_PROVIDER=mock
AI_BASE_URL=
AI_API_KEY=
AI_TIMEOUT_MS=8000
AI_SERVICE_TIMEOUT_MS=5000
