NOTIFICATION_WS_ALLOWED_ORIGINS=http://localhost:5174,http://127.0.0.1:5174
JWT_EXPIRE_HOURS=24
GATEWAY_PORT=18080
NGINX_PORT=18000

JAVA_TOOL_OPTIONS=-XX:MaxRAMPercentage=70 -XX:+ExitOnOutOfMemoryError
