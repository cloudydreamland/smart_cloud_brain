DB_ROOT_PASSWORD=root_password
KINGBASE_SYSTEM_PASSWORD=kingbase_dev_password
DB_PORT=54321
DB_SERVICE_HOST=kingbase
DB_SERVICE_PORT=54321

KINGBASE_IMAGE=kingbase_v009r001c010b0004_single_x86:v1
KINGBASE_DB_MODE=pg
DB_INTERNAL_PORT=54321
